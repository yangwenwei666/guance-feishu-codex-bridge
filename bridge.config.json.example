{
  "host": "127.0.0.1",
  "port": 4319,
  "commandPrefix": "/codex",
  "sharedSecret": "change-this-local-secret",
  "feishu": {
    "appId": "cli_xxxxx",
    "appSecret": "your-feishu-app-secret",
    "verificationToken": "your-event-verification-token"
  },
  "codex": {
    "codexHome": "/Users/your-name/.codex",
    "allowDangerouslyBypassApprovals": false,
    "replyLanguage": "zh-CN"
  },
  "security": {
    "allowedUserIds": [],
    "requireSharedSecretForManualSend": true
  },
  "profiles": {
    "default": {
      "label": "Default Workspace",
      "cwd": "/absolute/path/to/your/project",
      "sessionId": "YOUR-CODEX-SESSION-ID",
      "instructions": "Act on this workspace carefully. Keep replies concise and practical."
    },
    "guance": {
      "label": "Guance PaaS",
      "cwd": "/absolute/path/to/guanceyun-paas",
      "sessionId": "YOUR-CODEX-SESSION-ID",
      "instructions": "You are working in the guanceyun-paas workspace."
    }
  }
}
